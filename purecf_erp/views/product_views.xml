<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Product Template Inherit Views -->
    <record id="product_template_form_view_inherit_purecf" model="ir.ui.view">
        <field name="name">product.template.form.inherit.purecf</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <div class="d-inline-block">
                    <field name="x_is_ingredient"/>
                    <label for="x_is_ingredient"/>
                </div>
                <div class="d-inline-block ms-3">
                    <field name="x_is_purecf_product"/>
                    <label for="x_is_purecf_product" string="Is Purecf?"/>
                </div>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Purecf ERP Info" name="purecf_info">
                    <group>
                        <group string="Inventory &amp; Vendors">
                            <field name="x_vendor_id"/>
                        </group>
                        <group string="Point of Sale">
                            <field name="pos_categ_ids" widget="many2many_tags" string="POS Categories"/>
                        </group>
                    </group>
                </page>
                <page string="Recipes (BoM)" name="purecf_bom">
                    <field name="x_main_bom_id" invisible="1"/>
                    <div invisible="x_main_bom_id != False" class="m-3">
                        <p class="text-muted mb-2">This product does not have a Bill of Materials (Recipe) yet.</p>
                        <button name="action_create_bom" type="object" string="Create Recipe" class="btn-primary"/>
                    </div>
                    <field name="x_bom_line_ids" invisible="x_main_bom_id == False">
                        <tree editable="bottom">
                            <field name="product_id"/>
                            <field name="product_qty"/>
                            <field name="product_uom_category_id" invisible="1"/>
                            <field name="product_uom_id" groups="uom.group_uom"/>
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="x_unit_cost" string="Price/Qty" widget="monetary"/>
                            <field name="x_total_cost" string="Total" widget="monetary" sum="Total Cost"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="product_template_search_view_inherit_purecf" model="ir.ui.view">
        <field name="name">product.template.search.inherit.purecf</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='filter_to_sell']" position="after">
                <separator/>
                <filter string="Ingredients" name="is_ingredient" domain="[('x_is_ingredient', '=', True)]"/>
                <filter string="Purchasable (Vendor)" name="is_purchasable" domain="[('purchase_ok', '=', True)]"/>
                <filter string="Inventory Managed" name="is_inventory" domain="['|', ('x_is_ingredient', '=', True), ('purchase_ok', '=', True)]"/>
                <filter string="Saleable Menus" name="is_menu" domain="[('x_is_ingredient', '=', False), ('sale_ok', '=', True)]"/>
                <separator/>
                <filter string="Purecf Catalog" name="is_purecf" domain="[('x_is_purecf_product', '=', True)]"/>
            </xpath>
        </field>
    </record>
</odoo>
