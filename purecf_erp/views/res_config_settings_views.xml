<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.purecf</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="90"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Purecf ERP" string="Purecf ERP" name="purecf_erp">
                    <block title="General Settings" name="purecf_general_settings">
                        <setting string="Financial Closing" help="Configure when the monthly financial snapshot is taken.">
                            <div class="content-group">
                                <div class="mt16">
                                    <label for="closing_day" string="Closing Day of Month"/>
                                    <field name="closing_day" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Security" help="Manage global security parameters for the POS application.">
                            <div class="content-group">
                                <div class="mt16">
                                    <label for="purecf_admin_pin" string="Global Admin PIN"/>
                                    <field name="purecf_admin_pin" class="oe_inline" password="True"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_purecf_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'purecf_erp'}</field>
    </record>
</odoo>
